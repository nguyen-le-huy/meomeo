NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:5000

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database-name>?retryWrites=true&w=majority
# MONGO_URI is still supported for backward compatibility.
# MONGO_URI=

JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Cloudflare R2 is used for ebook files. Covers still use Cloudinary.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=meomeo
R2_REGION=auto
R2_ENDPOINT=
R2_EBOOK_PREFIX=ebooks
R2_PUBLIC_BASE_URL=

# Bunny Stream movie upload, encode, webhook and short-lived playback.
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_TOKEN_KEY=
BUNNY_STREAM_READ_ONLY_API_KEY=
BUNNY_STREAM_PULL_ZONE_HOST=
BUNNY_STREAM_UPLOAD_EXPIRES_IN=86400
BUNNY_STREAM_PLAYBACK_EXPIRES_IN=300

AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=southeastasia

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=123456

OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=deepseek-v4-pro
OPENAI_TRANSLATION_TARGET_LANGUAGE=vi
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_VOCABULARY_MODEL=gpt-5.4-mini-2026-03-17
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
OPENAI_DICTIONARY_MODEL=gpt-5.4-mini-2026-03-17

CAMBRIDGE_DICTIONARY_ENABLED=true
CAMBRIDGE_DICTIONARY_BASE_URL=https://dictionary.cambridge.org/dictionary/english-vietnamese
CAMBRIDGE_DICTIONARY_TIMEOUT_MS=1500
DICTIONARY_CACHE_TTL_SECONDS=86400
DICTIONARY_CACHE_MAX_ENTRIES=1000
